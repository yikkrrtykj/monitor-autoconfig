# 复制为 .env 后直接修改即可: cp .env.example .env && vi .env

# ==================== 基本配置 ====================
# 服务器的公网 IP（远程访问必填，修复 LibreNMS ServerName 校验）
SERVER_IP=

# SNMP Community（Zabbix / LibreNMS / Prometheus SNMP 通用）
SNMP_COMMUNITY=global
SNMP_TIMEOUT=1
SNMP_RETRIES=0

# ==================== Grafana ====================
GRAFANA_USER=admin
GRAFANA_PASSWORD=root
GRAFANA_PORT=3000

# ==================== Zabbix ====================
ZABBIX_WEB_PORT=8001
SWITCH_DISCOVERY_RANGE=192.168.10.1-100,192.168.10.254

# ==================== LibreNMS ====================
LIBRENMS_PORT=8002
LIBRENMS_BASE_URL=http://localhost:8002
LIBRENMS_DISCOVERY_TARGETS=192.168.10.1-100,192.168.10.254
LIBRENMS_CORE_IP=192.168.10.254
LIBRENMS_STAGE_START_OCTET=11
LIBRENMS_DISPATCHER_NODE_ID=dispatcher1
LIBRENMS_ADMIN_USER=admin
LIBRENMS_ADMIN_PASSWORD=admin
LIBRENMS_ADMIN_EMAIL=admin@example.com

# ==================== Prometheus ====================
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_SNMP_AUTH=global
PROMETHEUS_SCRAPE_INTERVAL=30s
PROMETHEUS_RETENTION_TIME=15d
# SNMP 设备 + ICMP 基础设施 Ping（交换机/防火墙/AP），逗号分隔，支持范围如 .11-16
PROMETHEUS_SNMP_TARGETS=192.168.10.254,192.168.10.11-16
PROMETHEUS_PING_TARGETS=192.168.10.254,192.168.10.11-16

# ==================== Exporter 端口 ====================
SNMP_EXPORTER_BIND=127.0.0.1
SNMP_EXPORTER_PORT=9116
BLACKBOX_EXPORTER_BIND=127.0.0.1
BLACKBOX_EXPORTER_PORT=9115

# ==================== 赛事选手监控 ====================
# 交换机通过 SNMP 读取端口 description "team X-Y" 自动生成选手→Team映射
TOURNAMENT_SWITCHES=192.168.10.11,192.168.10.12,192.168.10.13,192.168.10.14

# 选手有线/无线网段（/24，逗号分隔）
PLAYER_SUBNETS=192.168.11.0/24
WIRELESS_SUBNETS=192.168.12.0/24

# 基础设施Ping分组（交换机/防火墙/AP，逗号分隔IP或范围）
INFRA_SWITCH_PING_TARGETS=192.168.10.254,192.168.10.11-16
INFRA_FIREWALL_PING_TARGETS=
INFRA_AP_PING_TARGETS=
