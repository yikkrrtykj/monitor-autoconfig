# 复制为 .env 后修改: cp .env.example .env && vi .env

# ==================== 服务器 ====================
SERVER_IP=

# ==================== SNMP ====================
# ⚠️ 生产部署务必修改
SNMP_COMMUNITY=global
SNMP_TIMEOUT=1
SNMP_RETRIES=0

# ==================== Grafana ====================
# ⚠️ 生产部署务必修改 GRAFANA_PASSWORD
GRAFANA_USER=admin
GRAFANA_PASSWORD=root
GRAFANA_PORT=3000

# ==================== Zabbix ====================
ZABBIX_WEB_PORT=8001
SWITCH_DISCOVERY_RANGE=192.168.10.1-100,192.168.10.254

# ==================== LibreNMS ====================
LIBRENMS_PORT=8002
LIBRENMS_BASE_URL=http://localhost:8002
LIBRENMS_DISCOVERY_TARGETS=192.168.10.1-100,192.168.10.254
LIBRENMS_CORE_IP=192.168.10.254
LIBRENMS_STAGE_START_OCTET=11
LIBRENMS_DISPATCHER_NODE_ID=dispatcher1
# ⚠️ 生产部署务必修改 LIBRENMS_ADMIN_PASSWORD
LIBRENMS_ADMIN_USER=admin
LIBRENMS_ADMIN_PASSWORD=admin
LIBRENMS_ADMIN_EMAIL=admin@example.com

# ==================== Prometheus + Exporters ====================
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=30s
PROMETHEUS_RETENTION_TIME=15d
BLACKBOX_EXPORTER_BIND=127.0.0.1
BLACKBOX_EXPORTER_PORT=9115
SNMP_EXPORTER_BIND=127.0.0.1
SNMP_EXPORTER_PORT=9116

# ==================== 基础设施 Ping ====================
# 格式: 名称:IP，逗号分隔。名称显示在 Grafana 面板上，IP 是实际 Ping 目标。
# 支持 IP 范围: 名称:192.168.1.1-10

# 核心交换机（堆叠/集群）
CORE_SWITCH_PING=Core:192.168.10.254

# 分线/接入交换机（去不同区域的）
DIST_SWITCH_PING=SW1:192.168.10.11,SW2:192.168.10.12,SW3:192.168.10.13

# 防火墙（HA 主备都写上）
FIREWALL_PING=FW1:192.168.1.1,FW2:192.168.1.2

# 一般服务器/Core 等（原 PROMETHEUS_PING_TARGETS，不分组）
SERVER_PING=Server:192.168.10.254

# ==================== 防火墙 SNMP 流量 ====================
# 防火墙 IP，逗号分隔（HA 两台都写）
FIREWALL_SNMP_TARGETS=192.168.1.1,192.168.1.2
# WAN 口描述关键词，逗号分隔。匹配 ifAlias（端口 description）中含这些词的口
FIREWALL_WAN_IF_FILTER=telecom,telcom,unicom,isp,WAN

# ==================== 赛事选手监控 ====================
TOURNAMENT_SWITCHES=192.168.10.11,192.168.10.12
PLAYER_SUBNETS=192.168.11.0/24
WIRELESS_SUBNETS=192.168.12.0/24
