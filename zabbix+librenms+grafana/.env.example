# 复制为 .env 后修改: cp .env.example .env && vi .env

# ==================== 部署拉镜像 ====================
# deploy.sh 会默认串行拉镜像并自动重试，规避 Docker Hub/CDN 偶发 502。
COMPOSE_PARALLEL_LIMIT=1
IMAGE_PULL_RETRIES=5
IMAGE_PULL_RETRY_DELAY=20

# ==================== 服务器 ====================
SERVER_IP=
EVENT_NAME=

# ==================== SNMP ====================
# 生产部署务必修改
SNMP_COMMUNITY=public
SNMP_TIMEOUT=1
SNMP_RETRIES=0

# ==================== Grafana ====================
# 生产部署务必修改GRAFANA_PASSWORD
GRAFANA_USER=admin
GRAFANA_PASSWORD=root
GRAFANA_PORT=3000
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ALLOW_EMBEDDING=true

# ==================== 对外展示大屏 ====================
BIGSCREEN_PORT=8088
BIGSCREEN_TITLE=
BIGSCREEN_SUBTITLE=
BIGSCREEN_LOGO_TEXT=
# 8088 大屏和 Grafana ISP 面板共用这个名单
BIGSCREEN_ISP_NAMES=ISP1,ISP2
# false = 严格按 BIGSCREEN_ISP_NAMES 显示；true = 再自动加入 Prometheus 发现到的 WAN 口
BIGSCREEN_ISP_AUTO_DISCOVER=false
# 大屏基础设施只显示舞台相关设备，按设备名匹配，逗号分隔
BIGSCREEN_STAGE_DEVICE_FILTER=stage,wutai,舞台
BIGSCREEN_GRAFANA_BASE_URL=
# 默认通过 bigscreen 容器反代 Prometheus，不需要改。
BIGSCREEN_PROMETHEUS_BASE_URL=

# ==================== Zabbix ====================
ZABBIX_WEB_PORT=8001
SWITCH_DISCOVERY_RANGE=192.168.10.1-100,192.168.10.254

# ==================== LibreNMS ====================
LIBRENMS_PORT=8002
LIBRENMS_BASE_URL=http://localhost:8002
LIBRENMS_DISCOVERY_TARGETS=192.168.10.1-100,192.168.10.254
LIBRENMS_CORE_IP=192.168.10.254
LIBRENMS_STAGE_START_OCTET=11
LIBRENMS_DISPATCHER_NODE_ID=dispatcher1
LIBRENMS_ADMIN_USER=admin
LIBRENMS_ADMIN_PASSWORD=admin123
LIBRENMS_ADMIN_EMAIL=admin@example.com

# ==================== Prometheus + Exporters ====================
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=10s
PROMETHEUS_RETENTION_TIME=15d
BLACKBOX_EXPORTER_BIND=127.0.0.1
BLACKBOX_EXPORTER_PORT=9115
SNMP_EXPORTER_BIND=127.0.0.1
SNMP_EXPORTER_PORT=9116

# ==================== 基础设施 Ping ====================
# 格式: 名称:IP，逗号分隔。名称显示在 Grafana 面板上，IP 是实际 Ping 目标。
# 支持 IP 范围: 名称:192.168.1.1-10

# 核心交换机（堆叠/集群）
CORE_SWITCH_PING=Core:192.168.10.254

# 分线/接入交换机（去不同区域的）
DIST_SWITCH_PING=SW1:192.168.10.11,SW2:192.168.10.12,SW3:192.168.10.13

# 防火墙（HA 主备都写上）
FIREWALL_PING=FW1:192.168.9.5,FW2:192.168.9.6

# 一般服务器/Core 等
SERVER_PING=Core:192.168.10.254,server=

# ==================== 防火墙 SNMP 流量 ====================
FIREWALL_SNMP_TARGETS=FW1:192.168.9.5,FW2:192.168.9.6
# WAN 口描述关键词，逗号分隔。匹配 ifAlias（端口 description）中含这些词的口
FIREWALL_WAN_IF_FILTER=telecom,telcom,unicom,isp,WAN

# ==================== 赛事选手监控 ====================
TOURNAMENT_SWITCHES=192.168.10.11,192.168.10.12
PLAYER_SUBNETS=192.168.40.0/24
WIRELESS_SUBNETS=192.168.41.0/24
# 选手网关 IP（L3 设备，承载 player VLAN 网关 / ARP 表）。
# 舞台交换机是纯 L2 时必须设置：脚本会查这里的 ARP 表拿 IP→MAC，再用
# 舞台交换机的 MAC 表反推到 team X-Y 端口。留空则回退到 LIBRENMS_CORE_IP；
# 都为空只走旧的“在舞台交换机直接 ARP”路径，纯 L2 部署会拿不到选手数据。
# 例: PLAYER_GATEWAYS=192.168.10.254,192.168.9.5,192.168.9.6
PLAYER_GATEWAYS=
# 网关 SNMP community 与舞台交换机不同时在这里覆盖，否则用 SNMP_COMMUNITY。
PLAYER_GATEWAY_SNMP_COMMUNITY=
# 选手 VLAN ID 列表（逗号分隔）。Cisco/H3C 默认只在 VLAN 1 暴露 BRIDGE-MIB MAC 表，
# 设上 VLAN 后脚本会用 community@vlan_id 形式查每个 VLAN 的 MAC 表合并起来。
# 例: PLAYER_VLAN_IDS=11,12   （11=有线选手，12=无线选手 AP 上行）
PLAYER_VLAN_IDS=
# 无线扫描：只按 WIRELESS_SUBNETS ping 扫在线 IP，生成 network=wireless 的选手 targets。
# 面板选 wired 只看有线，选 wireless 只看无线扫描，互不影响。
# 无线不知道真实座位，左右队和座位只是按 IP 排序临时分配，用来看 WiFi 连接数量/效果。
# 默认开启，比赛中可以随时切到 wireless 看有没有人连 WiFi；不需要时改成 false。
# LIMIT=0 表示不限制在线 IP 数量，只受 PLAYER_WIRELESS_SCAN_MAX_HOSTS 的扫描保护限制。
PLAYER_WIRELESS_SCAN=true
PLAYER_WIRELESS_SCAN_LIMIT=0
PLAYER_WIRELESS_SCAN_TEAM_SIZE=5
# 默认排除每个无线网段的第一个/最后一个可用地址（常见网关 .1/.254）。
PLAYER_WIRELESS_SCAN_EXCLUDE_GATEWAYS=true
# 额外排除 AP/网关/服务器 IP，多个用逗号分隔；支持 Cisco 风格范围。
# 例: PLAYER_WIRELESS_SCAN_EXCLUDE=192.168.12.220-254,192.168.12.10
PLAYER_WIRELESS_SCAN_EXCLUDE=
# WiFi-only 比赛可手动指定选手 IP，格式: 队伍-座位=IP[:wired|wireless]
# 例: PLAYER_STATIC_TARGETS=1-1=192.168.12.101,1-2=192.168.12.102,2-1=192.168.12.201
PLAYER_STATIC_TARGETS=
PLAYER_STATIC_NETWORK=wireless
