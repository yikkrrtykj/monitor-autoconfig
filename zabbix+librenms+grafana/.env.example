# Copy this file to .env before running docker compose if your LAN changes.

# SNMP community used by Zabbix and LibreNMS.
# Prometheus snmp-exporter uses the auth profile named by PROMETHEUS_SNMP_AUTH.
SNMP_COMMUNITY=global

# LibreNMS scans these targets and adds only hosts that answer SNMP.
# Supported formats: single IP, last-octet range, comma-separated list.
# Example: 10.20.30.1-100,10.20.30.254
# On a remote server, set SERVER_IP to your server's public IP (REQUIRED).
# This fixes LibreNMS ServerName validation, nginx, and base URL.
SERVER_IP=
LIBRENMS_BASE_URL=http://localhost:8002
LIBRENMS_DISCOVERY_TARGETS=192.168.10.1-100,192.168.10.254
LIBRENMS_CORE_IP=192.168.10.254
LIBRENMS_STAGE_START_OCTET=11
LIBRENMS_DISPATCHER_NODE_ID=dispatcher1
SNMP_TIMEOUT=1
SNMP_RETRIES=0

# Zabbix discovery rule for switches.
SWITCH_DISCOVERY_RANGE=192.168.10.1-100,192.168.10.254

# Lightweight Prometheus targets used only for Grafana dashboards.
# Keep this small: core + stage switches by default.
PROMETHEUS_SNMP_TARGETS=192.168.10.254,192.168.10.11-16
PROMETHEUS_PING_TARGETS=192.168.10.254,192.168.10.11-16
PROMETHEUS_SNMP_AUTH=global
PROMETHEUS_SCRAPE_INTERVAL=30s
PROMETHEUS_RETENTION_TIME=15d

# LibreNMS default admin created on first run.
LIBRENMS_ADMIN_USER=admin
LIBRENMS_ADMIN_PASSWORD=admin
LIBRENMS_ADMIN_EMAIL=admin@example.com

# Grafana authentication for auto-setup.
GRAFANA_USER=admin
GRAFANA_PASSWORD=root

# Optional service ports.
GRAFANA_PORT=3000
ZABBIX_WEB_PORT=8001
LIBRENMS_PORT=8002
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_PORT=9090
SNMP_EXPORTER_BIND=127.0.0.1
SNMP_EXPORTER_PORT=9116
BLACKBOX_EXPORTER_BIND=127.0.0.1
BLACKBOX_EXPORTER_PORT=9115

# === PUBGM Tournament Player Monitoring ===
# Stage switches to query via SNMP for player IP -> Team/Seat mapping.
# Comma-separated switch IPs. These switches must have SNMP v2c enabled.
TOURNAMENT_SWITCHES=192.168.10.11

# Subnets where player devices are located.
# Comma-separated CIDR notation (/24 only recommended).
PLAYER_SUBNETS=192.168.35.0/24
WIRELESS_SUBNETS=192.168.66.0/24

# Infrastructure ping targets grouped by role for Grafana dashboards.
# Comma-separated IPs or ranges (e.g. 192.168.10.1-10).
INFRA_SWITCH_PING_TARGETS=192.168.10.254,192.168.10.11-16
INFRA_FIREWALL_PING_TARGETS=
INFRA_AP_PING_TARGETS=
# === End Player Monitoring ===
