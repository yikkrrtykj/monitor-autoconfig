  "description": "Event Infrastructure",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "center" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Device" },
            "properties": [{ "width": 120 }]
          },
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "width": 80 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "0": { "text": "OFFLINE", "color": "red" }, "1": { "text": "ONLINE", "color": "green" } } }
              ]}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Ping" },
            "properties": [{ "unit": "s", "width": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "Loss" },
            "properties": [{ "unit": "percentunit", "decimals": 1, "width": 80 }]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 101,
      "options": { "cellHeight": "sm", "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "probe_success{job=~\"infra-core-ping|infra-dist-ping|infra-fw-ping\"}",
          "format": "table", "instant": true, "legendFormat": "Status", "refId": "S"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "probe_icmp_duration_seconds{job=~\"infra-core-ping|infra-dist-ping|infra-fw-ping\",phase=\"rtt\"}",
          "format": "table", "instant": true, "legendFormat": "Ping", "refId": "L"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "probe_icmp_loss_ratio{job=~\"infra-core-ping|infra-dist-ping|infra-fw-ping\"}",
          "format": "table", "instant": true, "legendFormat": "Loss", "refId": "P"
        }
      ],
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "phase": true, "job": true },
            "renameByName": { "instance": "Device", "Value #S": "Status", "Value #L": "Ping", "Value #P": "Loss" }
          }
        }
      ],
      "title": "设备状态",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "fillOpacity": 15, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": true },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "green", "value": 0.0001 },
            { "color": "yellow", "value": 0.005 },
            { "color": "red", "value": 0.02 }
          ]},
          "unit": "s",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 200,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "probe_icmp_duration_seconds{job=~\"infra-core-ping|infra-dist-ping\",phase=\"rtt\"}", "legendFormat": "{{instance}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "probe_icmp_duration_seconds{job=~\"infra-fw-ping\",phase=\"rtt\"}", "legendFormat": "{{instance}}", "refId": "B" }
      ],
      "title": "所有设备 Ping 趋势",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "axisSoftMin": 0, "fillOpacity": 20, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineWidth": 2, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": true },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "IN" }, "properties": [{ "id": "displayName", "value": "下载" }, { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "OUT" }, "properties": [{ "id": "displayName", "value": "上传" }, { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 300,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "repeat": "wan_iface",
      "repeatDirection": "h",
      "maxPerRow": 2,
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "rate(ifHCInOctets{job=\"firewall-snmp\",ifAlias=\"$wan_iface\"}[1m]) * 8", "legendFormat": "IN", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "rate(ifHCOutOctets{job=\"firewall-snmp\",ifAlias=\"$wan_iface\"}[1m]) * 8", "legendFormat": "OUT", "refId": "B" }
      ],
      "title": "$wan_iface · ISP 流量",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["infrastructure", "event", "ping", "traffic"],
  "templating": {
    "list": [
