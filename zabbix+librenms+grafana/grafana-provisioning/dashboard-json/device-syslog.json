  "description": "交换机/防火墙 syslog —— 选设备、选级别、关键字搜索",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "当前范围内 error 及以上级别的日志条数",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"syslog\", host=~\"$host\", severity=~\"emerg|alert|crit|err\"} |~ \"(?i)$search\" [$__range]))",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "错误日志数(当前范围)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "按严重级别堆叠的日志量",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "none",
            "lineWidth": 0,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (severity) (count_over_time({job=\"syslog\", host=~\"$host\", severity=~\"$severity\"} |~ \"(?i)$search\" [$__interval]))",
          "legendFormat": "{{severity}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "日志量(按级别)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 22, "w": 24, "x": 0, "y": 6 },
      "id": 3,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"syslog\", host=~\"$host\", severity=~\"$severity\"} |~ \"(?i)$search\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "日志",
      "type": "logs"
    }
  ],
