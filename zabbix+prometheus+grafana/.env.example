# Copy this file to .env before running docker compose if your LAN changes.

# SNMP community used by Zabbix and LibreNMS.
# Prometheus snmp-exporter uses the auth profile named by PROMETHEUS_SNMP_AUTH.
SNMP_COMMUNITY=global

# LibreNMS scans these targets and adds only hosts that answer SNMP.
# Supported formats: single IP, last-octet range, comma-separated list.
# Example: 10.20.30.1-100,10.20.30.254
LIBRENMS_DISCOVERY_TARGETS=192.168.10.1-100,192.168.10.254
LIBRENMS_CORE_IP=192.168.10.254
LIBRENMS_STAGE_START_OCTET=11
SNMP_TIMEOUT=1
SNMP_RETRIES=0

# Zabbix discovery rule for switches.
SWITCH_DISCOVERY_RANGE=192.168.10.1-100,192.168.10.254

# Lightweight Prometheus targets used only for Grafana dashboards.
# Keep this small: core + stage switches by default.
PROMETHEUS_SNMP_TARGETS=192.168.10.254,192.168.10.11-16
PROMETHEUS_PING_TARGETS=192.168.10.254,192.168.10.11-16
PROMETHEUS_SNMP_AUTH=global
PROMETHEUS_SCRAPE_INTERVAL=30s
PROMETHEUS_RETENTION_TIME=15d

# LibreNMS default admin created on first run.
LIBRENMS_ADMIN_USER=admin
LIBRENMS_ADMIN_PASSWORD=admin
LIBRENMS_ADMIN_EMAIL=admin@example.com

# Optional service ports.
GRAFANA_PORT=3000
ZABBIX_WEB_PORT=8001
LIBRENMS_PORT=8002
PROMETHEUS_PORT=9090
