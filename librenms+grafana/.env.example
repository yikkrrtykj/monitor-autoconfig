# 复制为 .env 后修改: cp .env.example .env && vi .env

# ==================== 部署拉镜像 ====================
# deploy.sh 会默认串行拉镜像并自动重试，规避 Docker Hub/CDN 偶发 502。
COMPOSE_PARALLEL_LIMIT=1
IMAGE_PULL_RETRIES=5
IMAGE_PULL_RETRY_DELAY=20

# ==================== 服务器 ====================
# 监控服务器自己的 IP（用于拼 LibreNMS 访问地址等）。
# 留空 → 跑 deploy.sh 时自动探测本机 IP 并写回这里；换场地想重新探测就再清空。
SERVER_IP=
EVENT_NAME=

# ==================== SNMP ====================
# 生产部署务必修改
SNMP_COMMUNITY=public
SNMP_TIMEOUT=1
SNMP_RETRIES=0

# ==================== Grafana ====================
# 生产部署务必修改 GRAFANA_PASSWORD
GRAFANA_USER=admin
GRAFANA_PASSWORD=root
GRAFANA_PORT=3000
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ALLOW_EMBEDDING=true

# ==================== 对外展示大屏 ====================
BIGSCREEN_PORT=8088
BIGSCREEN_TITLE=
BIGSCREEN_SUBTITLE=
BIGSCREEN_LOGO_TEXT=
# ISP 名字默认全自动发现：按下方 FIREWALL_WAN_IF_FILTER 关键词匹配防火墙 WAN 口的
# 接口描述(ifAlias/ifName/ifDescr)，换场地设备/口描述变了也不用改。
# 想手动指定或固定顺序，再加回： BIGSCREEN_ISP_NAMES=名字1,名字2 （名字要和口描述一致）
# ISP 出口 IP（拓扑页显示用）。留空自动用下面的 ISP_PING，不用重复填；
# 只有想让拓扑显示的 IP 和 ISP_PING 不一样时才单独填。格式: 名称:IP，逗号分隔。
BIGSCREEN_ISP_IPS=
# ISP WAN 口发现方式：true=按 FIREWALL_WAN_IF_FILTER 关键词自动发现（默认，推荐）；
# false=只显示手动写在 BIGSCREEN_ISP_NAMES 里的名字。
BIGSCREEN_ISP_AUTO_DISCOVER=true
# 自动发现匹配的 WAN 口关键词，逗号分隔。匹配 ifAlias/ifName/ifDescr 中含这些词的口（不区分大小写）。
# 建议在防火墙接口描述里写 telecom/unicom/WAN；如果现场来不及写描述，也可直接填端口名，
# 例如: telecom,telcom,unicom,isp,WAN,xethernet0/24,ethernet0/2
# 换场地若用别的描述（如 dianxin/liantong），往这里加关键词即可。
FIREWALL_WAN_IF_FILTER=telecom,telcom,unicom,isp,WAN
# ISP 单条链路最大带宽（Mbps）。大屏曲线/卡顿分析用它判断饱和；
# librenms-config 也会把防火墙 WAN 口速率覆盖成这个值，让 LibreNMS 的
# port_usage_perc 告警按运营商实际带宽算，而不是按物理口 1G/10G 算。
# 支持三种写法：
#   1000                    所有 ISP 上下行都是 1000 Mbps（最简单）
#   ISP1:1000,ISP2:500      每个 ISP 不同速率，上下行相等
#   ISP1:1000/100,ISP2:500/50   上下行不对等，格式 下行/上行（适合非对称专线）
BIGSCREEN_ISP_MAX_BANDWIDTH=1000
# ISP 带宽饱和告警阈值（百分比）。LibreNMS 对防火墙 WAN 口 port_usage_perc 超此值时推飞书。
ISP_SATURATION_PERCENT=80
# 大屏基础设施只显示舞台相关设备，按设备名匹配，逗号分隔
BIGSCREEN_STAGE_DEVICE_FILTER=stage,wutai,舞台
# 默认通过 bigscreen 容器反代 Prometheus，不需要改。
BIGSCREEN_PROMETHEUS_BASE_URL=

# ==================== 网络拓扑 LLDP 自动发现 ====================
# topology-collector 容器每 N 秒 SNMP walk LLDP-MIB，画出真实邻接图 + 接口流量。
# 前提：所有 Cisco 交换机/防火墙开启 LLDP（IOS: 'lldp run' 全局；查看 'show lldp neighbors'）
# TOPOLOGY_DEVICES 空则自动取 CORE_SWITCH_PING + DIST_SWITCH_PING + FIREWALL_PING +
# TOURNAMENT_SWITCHES 里所有 IP。手工填写覆盖此规则，逗号分隔。
TOPOLOGY_DEVICES=
# 采集周期（秒），默认 600（10 分钟）。拓扑赛中基本不变，没必要频繁全量 walk 所有交换机；
# 拉长可显著减轻 2960 等弱 CPU 交换机的控制平面负担，避免管理口 ping 周期性尖峰。
TOPOLOGY_REFRESH_INTERVAL=600
# /topology 页面查接口流量 rate() 的窗口，1m 比 30s 抖动小
TOPOLOGY_LINK_RATE_WINDOW=1m

# ==================== LibreNMS ====================
LIBRENMS_PORT=8002
# LibreNMS 访问地址（= Laravel APP_URL，validate 会校验它和你实际访问的地址一致）。
# 留空则自动用 http://<SERVER_IP>:<LIBRENMS_PORT>，所以记得把最上面的 SERVER_IP 填成
# 你的服务器 IP。也可在这里手动写死成别的地址。
LIBRENMS_BASE_URL=
# 交换机子网须覆盖在这里（默认已包含 192.168.10.x）。
# 新交换机满足 ①同网段 SNMP 已开启 ②连核心并开 lldp run，LibreNMS 5 分钟内自动发现，无需手动添加。
LIBRENMS_DISCOVERY_TARGETS=192.168.10.1-100,192.168.10.254
# 防火墙 IP 发现范围，逗号分隔，支持 x.x.x.a-b 格式
FIREWALL_DISCOVERY_RANGE=172.25.9.2-253,192.168.9.1-254
# 核心设备 IP（LibreNMS 给它打 "Core" 标签、选手网关 ARP 兜底用）。
# 留空自动取 CORE_SWITCH_PING 的 IP，不用重复填。
LIBRENMS_CORE_IP=
LIBRENMS_STAGE_START_OCTET=11
LIBRENMS_DISPATCHER_NODE_ID=dispatcher1
LIBRENMS_ADMIN_USER=admin
LIBRENMS_ADMIN_PASSWORD=librenms123
LIBRENMS_ADMIN_EMAIL=admin@example.com
# API Token 用于自动配置飞书 transport。留空时脚本自动尝试创建；
# 如果自动创建失败，到 LibreNMS → My Account → API Access → Create Token 手动生成后填入，
# 然后 docker compose up -d --force-recreate librenms-config 重跑一次。
LIBRENMS_API_TOKEN=

# ==================== Prometheus + Exporters ====================
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=10s
# 选手 ICMP 探测的单独采集间隔。默认 5s——比全局 10s 更密，纠纷回查时的时间分辨率
# 翻倍；blackbox 对几十个选手目标的负载可以忽略。大屏延迟查询页的 step=5 与此对齐。
PLAYER_PING_SCRAPE_INTERVAL=5s
PROMETHEUS_RETENTION_TIME=15d
# 交换机/防火墙 uptime（运行时长）SNMP 的单独采集间隔。运行时长是"天"级别，不必跟随
# 全局高频采集；拉长能减轻弱 CPU 交换机(如 2960)的控制平面负担，避免管理口 ping 周期性尖峰。
# 防火墙流量(if_mib)仍走全局快频率，不受此项影响（ISP 曲线需要分辨率）。默认 600s（10 分钟）。
SNMP_UPTIME_SCRAPE_INTERVAL=600s
BLACKBOX_EXPORTER_BIND=127.0.0.1
BLACKBOX_EXPORTER_PORT=9115
SNMP_EXPORTER_BIND=127.0.0.1
SNMP_EXPORTER_PORT=9116

# ==================== 飞书告警 ====================
# LibreNMS 网络告警 Feishu 机器人 token（设备离线/接口 down/ISP 带宽饱和）。
# 群里加机器人 → 自定义机器人 → 拷贝 /hook/ 后面那段。直接粘整条 URL 也行。
# 留空则告警只在 LibreNMS 内记录，不推飞书。
FEISHU_ROBOT_TOKEN=
# 调试模式：true 时 bridge 只记日志，不真发飞书，方便测试告警规则。
FEISHU_BRIDGE_DRY_RUN=false
# 新设备上线推送间隔（秒）。bridge 每隔这么久轮询 LibreNMS 设备列表，
# 新设备出现时自动推飞书"🟢 新设备上线"通知。默认 30 秒，体感接近即时；
# 设备列表查询很轻量，不必担心压力。想更省可调大（如 60）。
SWITCH_WATCH_INTERVAL=30

# ==================== 设备日志 syslog（→ Loki → Grafana）====================
# 交换机/防火墙把 syslog 发到「监控服务器IP:514」，rsyslog 收下(udp/tcp 都行)写文件，
# Promtail 读文件推给 Loki；在 Grafana Explore（数据源选 Loki）里搜查看历史日志。
# 设备侧只需加一行(Cisco IOS 全局配置)：logging host <监控服务器IP>
# 并在宿主机放行 514/udp。改监听端口改这里(容器内固定 514)。
SYSLOG_PORT=514

# ==================== 基础设施 Ping ====================
# 格式: 名称:IP，逗号分隔。名称显示在 Grafana 面板上，IP 是实际 Ping 目标。
# 支持 IP 范围: 名称:192.168.1.1-10；范围会自动命名为 名称1、名称2...

# 核心交换机（堆叠/集群）
CORE_SWITCH_PING=Core:192.168.10.254

# 分线/接入交换机（去不同区域的）
DIST_SWITCH_PING=SW:192.168.10.11-13

# ISP 出口 Ping（LibreNMS ping-only 设备，监控 ISP 连通性）。ISP 出口 IP 填这一处即可，
# 上面大屏拓扑（BIGSCREEN_ISP_IPS）会自动用。格式: 名称:IP，逗号分隔。
# 例: ISP_PING=ISP1:203.0.113.1,ISP2:198.51.100.1
ISP_PING=

# 防火墙 Ping：只写物理节点（拓扑图就显示这几台）。IP 要填防火墙真正回 ping 的口，
# 否则拓扑/丢包图会一直红。HA 逻辑 VIP 不用放这里——它在下面 FIREWALL_SNMP_TARGETS
# 里走 SNMP（看流量/运行时长）即可。
FIREWALL_PING=FW1:192.168.11.2,FW2:192.168.11.3

# 游戏服务器（只放游戏/业务服务器，一般就几台，会单独显示成一行）。格式: 名称:IP，逗号分隔。
# 名称用短名（server1、server2…），别用 IP 当名称，否则拓扑节点里会和延迟数字挤在一起。
# Core、交换机不要写这里——它们在上面的 CORE_SWITCH_PING / DIST_SWITCH_PING。
SERVER_PING=server1:192.168.141.15,server2:192.168.141.16,server3:192.168.141.17

# ==================== 防火墙 SNMP 流量 ====================
# HA 场景只填逻辑 IP：SNMP 从活跃节点拿数据，HA 切换后自动跟随，不会重复采集
# 名称就是大屏上显示的名字，简短点（例: FW:192.168.11.4）
# librenms-config 启动时会自动将这里的 IP 注册到 LibreNMS 作为 SNMP 设备
FIREWALL_SNMP_TARGETS=FW:192.168.11.4

# ==================== 赛事选手监控 ====================
# 选手发现周期（秒），默认 300。脚本每周期在每台舞台交换机上走一遍 MAC/ARP 表来定位
# 选手座位，这是交换机 SNMP 负载的主要来源。接入交换机 CPU 弱（如 2960）时，拉长间隔
# 能显著减轻控制平面负担。
#
# 注意：这个间隔只影响"重新发现有哪些目标"，不影响"已发现目标多久 ping 一次"——
# 已在册的选手由 blackbox 每 5s 探测，掉线 ~5s 内就会在大屏显示离线，不受此值影响。
# 唯一受影响的是"换设备拿到新 IP"的识别延迟。为此座位核对页提供了"立即重扫"按钮（↻），
# 选手换电脑/手机后点一下即可秒级触发有线重扫，不必等下一个周期。所以默认拉到 300。
PLAYER_TARGETS_REFRESH_INTERVAL=300
TOURNAMENT_SWITCHES=192.168.10.11,192.168.10.12
PLAYER_SUBNETS=192.168.40.0/24
WIRELESS_SUBNETS=192.168.41.0/24
# 选手网关 IP（L3 设备，承载 player VLAN 网关 / ARP 表）。
# 舞台交换机是纯 L2 时必须设置：脚本会查这里的 ARP 表拿 IP→MAC，再用
# 舞台交换机的 MAC 表反推到 team X-Y 端口。留空则回退到 LIBRENMS_CORE_IP；
# 都为空只走旧的“在舞台交换机直接 ARP”路径，纯 L2 部署会拿不到选手数据。
# 例: PLAYER_GATEWAYS=192.168.10.254,192.168.9.5,192.168.9.6
PLAYER_GATEWAYS=
# 选手 VLAN ID 列表（逗号分隔）。Cisco/H3C 默认只在 VLAN 1 暴露 BRIDGE-MIB MAC 表，
# 设上 VLAN 后脚本会用 community@vlan_id 形式查每个 VLAN 的 MAC 表合并起来。
# ⚠️ 只列“有线选手”的 VLAN。每多列一个 VLAN，脚本每 60 秒就在每台舞台交换机上多走一整遍
#    BRIDGE-MIB MAC 表，会加重弱 CPU 交换机（如 2960）的控制平面负担，表现为其管理口 ICMP
#    周期性尖峰（数据转发走硬件，不影响选手）。无线选手请用 PLAYER_WIRELESS_SCAN /
#    PLAYER_STATIC_TARGETS 发现，别把无线 VLAN 加进来——无线 MAC 落在 AP 上行口、匹配不到
#    座位端口，纯属白走还压 CPU。
# 例: PLAYER_VLAN_IDS=40   （只列有线 VLAN；40 对应上面的 PLAYER_SUBNETS=192.168.40.0/24）
PLAYER_VLAN_IDS=
# 端口 link-down 时跳过该 team 位（默认开）。交换机 MAC 老化要 5 分钟、网关 ARP
# 老化要 4 小时，断开后这两个表里残留的条目会让脚本误以为有人，造成"挂着显示红色"。
# 开启后下次脚本运行（60 秒内）就会自动清掉幻影 target。
PLAYER_REQUIRE_LINK_UP=true
# 主动 ping 验证（默认开）。每个候选 IP 在写入 player_targets.json 之前先 ping 一下，
# 不响应的不发出来。修掉同一端口 stale MAC 残留导致一座两 IP / WoL 幻影等问题。
# 关掉后回退到 link-up + 网关 ARP 直接信任的旧逻辑。
PLAYER_VERIFY_PING=true
# 无线扫描：只按 WIRELESS_SUBNETS ping 扫在线 IP，生成 network=wireless 的选手 targets。
# 面板选 wired 只看有线，选 wireless 只看无线扫描，互不影响。
# 无线不知道真实座位，左右队和座位只是按 IP 排序临时分配，用来看 WiFi 连接数量/效果。
# 默认开启，比赛中可以随时切到 wireless 看有没有人连 WiFi；不需要时改成 false。
# LIMIT=0 表示不限制在线 IP 数量，只受 PLAYER_WIRELESS_SCAN_MAX_HOSTS 的扫描保护限制。
PLAYER_WIRELESS_SCAN=true
PLAYER_WIRELESS_SCAN_LIMIT=0
PLAYER_WIRELESS_SCAN_TEAM_SIZE=5
# 注意：若选手实际占用了 .1 或 .254（比如网关只在 .254、而 .1 是真选手），把本项设
# false，再用下面的 PLAYER_WIRELESS_SCAN_EXCLUDE 手动只列出真实网关，避免误排除选手。
PLAYER_WIRELESS_SCAN_EXCLUDE_GATEWAYS=true
# 额外排除 AP/网关/服务器 IP，多个用逗号分隔；支持 Cisco 风格范围。
# 例: PLAYER_WIRELESS_SCAN_EXCLUDE=192.168.12.220-254,192.168.12.10
PLAYER_WIRELESS_SCAN_EXCLUDE=
# WiFi-only 比赛可手动指定选手 IP，格式: 队伍-座位=IP[:wired|wireless]
# 例: PLAYER_STATIC_TARGETS=1-1=192.168.12.101,1-2=192.168.12.102,2-1=192.168.12.201
PLAYER_STATIC_TARGETS=
PLAYER_STATIC_NETWORK=wireless
