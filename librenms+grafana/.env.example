# ==================== 部署拉镜像 ====================
# deploy.sh 会默认串行拉镜像并自动重试。
COMPOSE_PARALLEL_LIMIT=1
IMAGE_PULL_RETRIES=5
IMAGE_PULL_RETRY_DELAY=20

# 可选：离线/稳定交付时可锁定镜像。默认值在 docker-compose.yml 里。
MARIADB_IMAGE=
REDIS_IMAGE=
RRDCACHED_IMAGE=crazymax/rrdcached:1.9.0-r4
ALPINE_IMAGE=
PYTHON_SLIM_IMAGE=python:3.13-slim
PROMETHEUS_IMAGE=
SNMP_EXPORTER_IMAGE=
BLACKBOX_EXPORTER_IMAGE=
GRAFANA_IMAGE=
NGINX_IMAGE=
LIBRENMS_IMAGE=librenms/librenms:26.6.1
UNPOLLER_IMAGE=
PLAYER_TOOLS_IMAGE=monitor-player-tools:local
PLATFORM_API_IMAGE=monitor-platform-api:local
RSYSLOG_IMAGE=monitor-rsyslog:local
GRAFANA_SETUP_IMAGE=monitor-grafana-setup:local

# ==================== 服务器 ====================
# 监控服务器自己的 IP。
# 留空 → 跑 deploy.sh 时自动探测本机 IP 并写回这里；换场地想重新探测就再清空。
SERVER_IP=
EVENT_NAME=

# ==================== SNMP ====================
SNMP_COMMUNITY=global
SNMP_TIMEOUT=1
SNMP_RETRIES=0

# ==================== Grafana ====================
GRAFANA_USER=admin
GRAFANA_PASSWORD=root
GRAFANA_PORT=3000
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ALLOW_EMBEDDING=true

# ==================== 对外展示大屏 ====================
BIGSCREEN_PORT=8088
BIGSCREEN_TITLE=
BIGSCREEN_SUBTITLE=
BIGSCREEN_LOGO_TEXT=
BIGSCREEN_DEFAULT_LAYOUT=tournament-64-2layer
PLATFORM_WRITE_ENABLED=true
# 赛事控制台账号。首次部署默认 admin / global，登录后会强制修改密码。
# 修改过密码后会写入 platform-state/auth.json，后续不会再被这里的默认密码覆盖。
PLATFORM_AUTH_ENABLED=true
PLATFORM_AUTH_FAILURE_WINDOW_SECONDS=300
PLATFORM_AUTH_FAILURE_LIMIT=5
PLATFORM_AUTH_LOCK_SECONDS=900
PLATFORM_TRANSACTION_RETENTION=50
PLATFORM_APPLY_STATUS_RETENTION=200
PLATFORM_ADMIN_USER=admin
PLATFORM_ADMIN_PASSWORD=global
PLATFORM_SESSION_HOURS=8
# 控制台走 HTTPS 公网访问时建议改 true；纯 HTTP 内网访问保持 false，否则浏览器不会带 cookie。
PLATFORM_COOKIE_SECURE=false
# 点“应用配置”后自动执行 apply-env.sh，让已启动容器读取新 .env。
# 需要 platform-api 挂载 Docker socket；内网使用时保持默认即可。
PLATFORM_APPLY_ENABLED=true
PLATFORM_APPLY_COMMAND=/bin/sh /workspace/apply-env.sh
PLATFORM_APPLY_TIMEOUT=300
# 手动 iperf3 测速的总超时；默认香港公共节点，也可在页面选择地区或填写自有服务器。
# 客户端已安装在 player-targets 工具容器里，宿主机无需另装，不会常驻占带宽。
PLATFORM_IPERF3_TIMEOUT=60
# 测速目标默认只允许公网地址(自定义公网节点直接填即可)。只有要测内网自建
# iperf3 服务器时才改 true——否则测速接口等于对内网开放了 TCP 端口探测。
PLATFORM_IPERF3_ALLOW_INTERNAL=false
# DHCP 面板直接复用 event-config.yml 里的 devices.core.ip。正常在赛事控制台的
# “核心/防火墙”区域保存 Telnet 信息；以下变量只作为旧安装迁移/首次启动的备用值。
# 支持 Cisco IOS/IOS-XE Telnet 的“用户名+密码”或仅密码登录；没有用户名时保持为空。
PLATFORM_DHCP_SWITCH_USERNAME=
PLATFORM_DHCP_SWITCH_PASSWORD=
# 核心登录后需要 enable 才能执行 show 命令时填写；不需要则留空。
PLATFORM_DHCP_SWITCH_ENABLE_PASSWORD=
PLATFORM_DHCP_SWITCH_PORT=23
PLATFORM_DHCP_SWITCH_TIMEOUT=8
# 仅打开并停留在 DHCP 页面时刷新，最小 30 秒；后台缓存会合并多标签请求。
PLATFORM_DHCP_REFRESH_SECONDS=60
# 单个控制台请求体上限（默认 1 MiB），避免异常大请求耗尽 API 内存。
PLATFORM_MAX_REQUEST_BODY_BYTES=1048576
# ISP 名字默认全自动发现：按下方 FIREWALL_WAN_IF_FILTER 关键词匹配防火墙 WAN 口。
# 运营商公网 IP 用于拓扑展示，也会作为 ping-only 设备加入 LibreNMS。格式: 名称:IP，逗号分隔。
BIGSCREEN_ISP_IPS=
# ISP WAN 口发现方式：按FIREWALL_WAN_IF_FILTER关键词自动发现；
# 防火墙 SNMP 只报 eth0/eth1 这类物理名时（如 WatchGuard，界面别名不进 SNMP），
# 直接把 WAN 物理口名加进来，如 telecom,telcom,unicom,isp,WAN,eth0,eth1；
# 以数字结尾的关键词按边界匹配，eth1 不会误配 eth10~eth15。
BIGSCREEN_ISP_AUTO_DISCOVER=true
FIREWALL_WAN_IF_FILTER=telecom,telcom,unicom,isp,WAN
# ISP 单条链路最大带宽（Mbps）。
# 支持三种写法：
#   1000                    所有 ISP 上下行都是 1000 Mbps
#   ISP1:1000,ISP2:500      每个 ISP 不同速率，上下行相等
#   ISP1:1000/100,ISP2:500/50   上下行不对等，格式 下行/上行
BIGSCREEN_ISP_MAX_BANDWIDTH=1000
# ISP 带宽饱和告警阈值（百分比）。例如 80 表示带宽配置值的 80%。
ISP_SATURATION_PERCENT=90
# ISP 实时告警：连续 N 秒超过 “BIGSCREEN_ISP_MAX_BANDWIDTH * ISP_SATURATION_PERCENT” 才推飞书。
ISP_ALERT_ENABLED=true
ISP_ALERT_FOR_SECONDS=5
ISP_ALERT_POLL_INTERVAL=5
ISP_ALERT_RATE_WINDOW=1m
ISP_ALERT_RESOLVE_SECONDS=30
ISP_ALERT_STATUS_INTERVAL=30
# 计数器跳变防护：换防火墙/HA 主备切换/重启时 SNMP 计数器突变，rate() 会算出
# 几十 Gbps 的假速率。速率超过"该口配置带宽 x 此倍数"的样本按毛刺丢弃。0=关闭。
ISP_ALERT_SPIKE_IGNORE_FACTOR=5
# WAN 流量序列整体消失(SNMP 不通/换防火墙后接口名不匹配)持续 N 秒后推送
# "外网流量采集中断"告警,恢复时推送恢复卡。0=关闭。
ISP_DATA_MISSING_ALERT_SECONDS=120
DEVICE_DOWN_ENABLED=true
DEVICE_DOWN_FOR_SECONDS=10
ISP_DOWN_FOR_SECONDS=10
DEVICE_DOWN_REQUIRE_SEEN_UP=true
DEVICE_DOWN_POLL_INTERVAL=1
DEVICE_DOWN_SAMPLE_WINDOW_SECONDS=5
# 恢复防抖：设备/ISP 恢复后要连续在线这么多秒才发“已恢复”，闪断期间不刷屏。
# 0=立刻发（普通设备默认）；ISP 默认 10 秒，专门压制外网一会通一会断的刷屏。
DEVICE_RECOVER_STABLE_SECONDS=0
ISP_RECOVER_STABLE_SECONDS=10
# 根因抑制：上游交换机挂了，它下面的设备只是“受害者”，只报最上层的根因那一条
# （卡片里带“下游 N 台折叠”）。依赖 LLDP 拓扑(edges.json)+核心 IP；拿不到就照常全报（不会漏）。
DEVICE_DOWN_ROOT_CAUSE_ENABLED=true
INFRA_PING_SCRAPE_INTERVAL=2s
ISP_PING_SCRAPE_INTERVAL=1s
BLACKBOX_ICMP_TIMEOUT=1s
DEVICE_DOWN_JOBS=infra-core-ping,infra-dist-ping,infra-fw-ping,infra-fw-unit-ping,infra-isp-ping,infra-srv-ping
# 分线/接入交换机离线满 48 小时后【发确认卡等人工确认】，确认删除才移除 LibreNMS
# 旧记录；不确认永远保留，绝不自动删。删除后再上线按新设备处理，不发旧恢复告警。
DEVICE_REENROLL_AFTER_SECONDS=172800
DEVICE_REENROLL_JOBS=infra-dist-ping
DEVICE_LIBRENMS_SYNC_RETRY_SECONDS=60
# 待删除确认卡的重发间隔（秒）。0 = 只发一次后安静等确认。
DEVICE_PENDING_DELETE_REALERT_SECONDS=0
# 候选范围里的设备第一次 ping 通时，只用于“纳入后续离线监控”和“尝试 SNMP 加入 LibreNMS”；
DEVICE_ONLINE_FROM_PING=false
# 新交换机 ping 通后自动调用 LibreNMS API 按 SNMP 加设备，等 LibreNMS 拿到真实 hostname 后再发上线通知。
DEVICE_AUTO_ADD_FROM_PING=true
DEVICE_AUTO_ADD_SNMP_JOBS=infra-core-ping,infra-dist-ping
FEISHU_BRIDGE_EVENT_ID_START=0
FEISHU_BRIDGE_STATE_DIR=/bridge-state
# ==================== 飞书自建应用（推荐） ====================
# 配置后普通告警优先由应用机器人发送，旧 FEISHU_ROBOT_TOKEN 仅作失败回退；
# 待删除确认卡还会带“确认删除/保留”按钮，并启动 feishu-ws 长连接边车。
# 长连接主动外连飞书云端，内网无需公网 IP、域名或端口映射。
# 未配置应用时，待删除设备仍可在赛事控制台确认。
# 配置步骤（飞书开放平台 open.feishu.cn）：
#   1. 创建企业自建应用，拿到 App ID / App Secret 填到下面；
#   2. 开启“机器人”能力；
#   3. 事件与回调 → 订阅方式选“使用长连接接收”，添加“卡片回传交互”(card.action.trigger)
#      和“接收消息”(im.message.receive_v1)；
#   4. 把这个应用机器人拉进你的告警群。
# 群内 @机器人 支持：帮助、查设备、查光功率、查异常光功率。
# 设了 FEISHU_APP_ID 后，apply-env.sh / deploy.sh 会自动把 feishu profile 加进 COMPOSE_PROFILES。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 主动告警目的群：可填群名或 oc_... Chat ID。机器人只在一个群时可留空；
# 多群时必须指定。@查询回复使用消息来源群，不依赖本项。
FEISHU_CHAT_ID=

INTERCONNECT_ALERT_ENABLED=true
INTERCONNECT_ALERT_FOR_SECONDS=5
INTERCONNECT_ALERT_POLL_INTERVAL=5
INTERCONNECT_ALERT_JOBS=infra-switch-ifmib
INTERCONNECT_PORT_FILTER=port-channel,portchannel,po,eth-trunk,bridge-aggregation,bundle-ether,lag,ae,be,trk
# 互联口只查核心交换机,如需同时查其它已上线交换机，格式同其它 ping 配置：Name:IP,Name2:IP2。
INTERCONNECT_SNMP_TARGETS=
SWITCH_IFMIB_SCRAPE_INTERVAL=10s

UPLINK_IF_FILTER=to-stage,to-core,to-dist,uplink
# LibreNMS 自带 STP topology changed 很容易把正常交换机染黄；互联口断链已经由
# bridge 秒级告警处理，所以默认压掉 STP 事件噪声。
LIBRENMS_SUPPRESS_STP_EVENTS=true
# 大屏基础设施只显示舞台相关设备，按设备名匹配，逗号分隔
BIGSCREEN_STAGE_DEVICE_FILTER=stage,wutai,舞台
# 默认通过 bigscreen 容器反代 Prometheus，不需要改。
BIGSCREEN_PROMETHEUS_BASE_URL=

# ==================== 网络拓扑 LLDP 自动发现 ====================
# topology-collector 容器每 N 秒 SNMP walk LLDP-MIB，画出真实邻接图 + 接口流量。
# 所有 Cisco 交换机/防火墙开启 LLDP（IOS: 'lldp run' 全局；查看 'show lldp neighbors'）
# TOPOLOGY_DEVICES 空则自动取 CORE_SWITCH_PING + DIST_SWITCH_PING + FIREWALL_PING + TOURNAMENT_SWITCHES 里所有 IP。手工填写覆盖此规则，逗号分隔。
TOPOLOGY_DEVICES=
# 采集周期（秒），默认 600（10 分钟）。
TOPOLOGY_REFRESH_INTERVAL=600
TOPOLOGY_LINK_RATE_WINDOW=1m

# ==================== LibreNMS ====================
LIBRENMS_PORT=8002
# 默认按当前浏览器地址生成 LibreNMS 链接，内网和外网都能看图。
# 一般留空即可。只有明确想把所有链接强制跳到一个固定外网域名/IP 时，
# 才填写 LIBRENMS_BASE_URL 并把 LIBRENMS_FORCE_BASE_URL=true。
# 忘写 http:// 时脚本会自动补 http://，但建议写完整。
LIBRENMS_BASE_URL=
LIBRENMS_FORCE_BASE_URL=false
# 交换机子网须覆盖在这里（默认已包含 192.168.10.x）
LIBRENMS_DISCOVERY_TARGETS=192.168.10.10-30,192.168.10.254
# 交换机自动发现（SWITCH_DISCOVERY_RANGE 由控制台按交换机管理网段自动生成）的调优：
# 发现循环先 ping 探活、只对活的做 SNMP，所以扫一个 /24 也很轻。一般不用改。
SWITCH_DISCOVERY_WORKERS=32          # 并发探测数
SWITCH_DISCOVERY_MAX_HOSTS=1024      # 单次最多探测地址数（防手滑填 /16）
SWITCH_DISCOVERY_PING_TIMEOUT=1      # ICMP 超时(秒)
SWITCH_DISCOVERY_SNMP_TIMEOUT=1      # SNMP 超时(秒)
# 防火墙 IP 发现范围
FIREWALL_DISCOVERY_RANGE=192.168.9.0/24
# 留空自动取 CORE_SWITCH_PING 的 IP，不用重复填。
LIBRENMS_CORE_IP=
LIBRENMS_DISPATCHER_NODE_ID=dispatcher1
LIBRENMS_ADMIN_USER=admin
LIBRENMS_ADMIN_PASSWORD=librenms123
LIBRENMS_ADMIN_EMAIL=admin@example.com
LIBRENMS_IGNORE_DOWN_PORTS=true
# LibreNMS 默认会把 uptime 小于 24 小时的在线设备标黄。
# 0 = 不按运行时长标黄，只看真实 up/down；想恢复默认提示可改成 86400。
LIBRENMS_UPTIME_WARNING_SECONDS=0
# LibreNMS 首页自动卡片。部署时会创建/更新一个“赛事网络总览”dashboard，
# 只管理它自己生成的卡片，不会删除你手动建的其它 dashboard。
# 首页默认优先放 WAN 流量图，然后是设备在线数、接口流量排名、设备流量排名、交换机 CPU 排名。
# 告警和日志不放首页，飞书负责告警；日志适合需要排障时再进 LibreNMS 看。
LIBRENMS_HOME_DASHBOARD_AUTO=true
LIBRENMS_HOME_DASHBOARD_NAME=赛事网络总览
LIBRENMS_HOME_WAN_CARDS=true
LIBRENMS_HOME_WAN_CARD_LIMIT=8
LIBRENMS_HOME_TOP_INTERFACES=true
LIBRENMS_HOME_TOP_DEVICES=true
LIBRENMS_HOME_SWITCH_CPU=true
# auto = 只有 SERVER_PING 配了服务器时才放服务器状态；true/false 可强制开关。
LIBRENMS_HOME_SERVER_STATS=auto
# API Token 供自动配置和现有告警 bridge 读取 LibreNMS；一般由初始化脚本自动生成。
LIBRENMS_API_TOKEN=

# ==================== Prometheus + Exporters ====================
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=10s
# 选手 ICMP 探测的单独采集间隔。
PLAYER_PING_SCRAPE_INTERVAL=5s
PROMETHEUS_RETENTION_TIME=15d
SNMP_UPTIME_SCRAPE_INTERVAL=600s
BLACKBOX_EXPORTER_BIND=127.0.0.1
BLACKBOX_EXPORTER_PORT=9115
SNMP_EXPORTER_BIND=127.0.0.1
SNMP_EXPORTER_PORT=9116

# ==================== 飞书告警 ====================
FEISHU_ROBOT_TOKEN=
# 调试模式：true 时 bridge 只记日志，不发飞书，方便测试告警规则。
FEISHU_BRIDGE_DRY_RUN=false
FEISHU_FAILED_EVENT_RETRY_SECONDS=30
FEISHU_FAILED_EVENT_MAX_ATTEMPTS=5
FEISHU_FAILED_EVENT_TTL_SECONDS=600
# 新设备上线推送间隔（秒）。
SWITCH_WATCH_INTERVAL=30

# ==================== 设备日志 syslog（→ Loki → Grafana）====================
# 设备需加一行：logging host <监控服务器IP>
# 并在宿主机放行 514/udp。改监听端口改这里(容器内固定 514)。
SYSLOG_PORT=514
SYSLOG_WATCH_ENABLED=true
# 默认只推高价值网络安全日志：串线、接口保护关闭、BPDU 保护、回环。
# mac_flap、storm_control 单独日志默认只进 Loki/LibreNMS，不推飞书。
SYSLOG_ALERT_TYPES=native_vlan_mismatch,errdisable,bpduguard,loopback
# 同一设备同一接口短时间内同时出现多类 syslog 告警时，按 串线 > 回环 > 接口保护关闭 只推最高优先级。
SYSLOG_CORRELATION_SECONDS=10
# 已推过的串线/回环/接口保护关闭，在同接口后续 link up 时推恢复。
SYSLOG_RECOVERY_ENABLED=true
# 闪断抑制：同一问题在同一端口最多每隔这么多秒重报一次（默认 600=10 分钟），
# 避免一个反复 up/down 的口每分钟刷一条。
SYSLOG_REALERT_SECONDS=600
# 恢复防抖：端口要连续正常这么多秒才发“已恢复”（默认 120）；期间又出问题就取消。
# 一个闪来闪去的口 → 收敛成 1 条告警 + 稳定后 1 条恢复。
SYSLOG_RECOVER_STABLE_SECONDS=120

# ==================== 基础设施 Ping ====================
# 格式: 名称:IP，逗号分隔。名称显示在 Grafana 面板上，IP 是实际 Ping 目标。
# 支持 IP 范围: 名称:192.168.1.1-10；范围会自动命名为 名称1、名称2...
# 核心交换机
CORE_SWITCH_PING=Core:192.168.10.254

# 接入交换机（去不同区域的）
DIST_SWITCH_PING=SW:192.168.10.11-14

# ISP 出口 Ping（LibreNMS ping-only 设备 + blackbox，监控 ISP 连通性）。探测从监控主机发出。
# 一般留空自动读取；只有设备不开放相关 SNMP 表时才手工填运营商网关。
# 例: ISP_PING=telecom:电信网关IP,unicom:联通网关IP
# 一般可以留空：ISP_GATEWAY_AUTO_DISCOVER=true 时会从防火墙 SNMP 读默认路由
# 下一跳自动发现网关（按 WAN 口名命名）。手工条目优先，自动发现只做补充；
# 防火墙不开放路由表 SNMP 时会退回读取 WAN 口公网 IP，不会留下空白节点。
ISP_PING=
ISP_GATEWAY_AUTO_DISCOVER=true
# WAN IP 单独刷新周期（秒）；不影响较重的 LLDP 拓扑采集周期。
ISP_DISCOVERY_REFRESH_INTERVAL=60

# 防火墙 Ping：控制台会和 FIREWALL_SNMP_TARGETS 使用同一组 IP；手工编辑 .env 时也可以按需分开。
FIREWALL_PING=

# 游戏服务器（只放游戏/业务服务器）。格式: 名称:IP，逗号分隔。
# Core、交换机不要写这里——它们在上面的 CORE_SWITCH_PING / DIST_SWITCH_PING。
SERVER_PING=

# ==================== 防火墙 SNMP ====================
# WAN 流量 SNMP：控制台默认复用防火墙 IP；HA 场景手工编辑时可填逻辑 VIP。
FIREWALL_SNMP_TARGETS=

# 物理节点 SNMP（HA 场景专用）：填每台物理机 IP。
# - Prometheus：新增 infra-fw-unit-snmp job 采集每台物理节点运行时长
# - LibreNMS：物理节点在 LibreNMS 中做完整 SNMP 监控（能看到硬件详情）
# - 未填：回退为旧逻辑，LibreNMS 用 FIREWALL_SNMP_TARGETS（VIP）做 SNMP（向后兼容）
FIREWALL_UNIT_SNMP_TARGETS=

# ==================== UniFi AP 监控 ====================
#   1. 填下面的 UNIFI_CONTROLLER_*（控制器地址 + 一个只读账号）。
#   2. ./deploy.sh（或 ./apply-env.sh）
# 控制器地址：
#   · UniFi OS 主机（UDM/UDM-Pro/Cloud Key Gen2 等）→ https://<控制器IP>      （443，自带 /proxy）
#   · 独立 Network 控制器（自建服务器）            → https://<控制器IP>:8443
# 账号：在控制器里建一个 View Only（只读）本地管理员专门给它用，别用主账号。
# 站点：默认 all（采集所有站点）；只要某个站点就填站点名（控制器 URL 里 /s/<这段>）。
UNIFI_CONTROLLER_URL=
UNIFI_CONTROLLER_USER=
UNIFI_CONTROLLER_PASS=
UNIFI_CONTROLLER_SITES=all
# 控制器多为自签证书，默认不校验；换了受信证书可改 true。
UNIFI_CONTROLLER_VERIFY_SSL=false
UNIFI_AP_ALERT_ENABLED=true
# AP 掉线确认时间。默认 180 秒，过滤 UniFi 控制器/API 的短闪断。
UNIFI_AP_DOWN_FOR_SECONDS=180
# AP watcher 轮询间隔。实际告警时间约为确认时间 + 0~一个轮询间隔。
UNIFI_AP_POLL_INTERVAL=5
# 在线 AP 自动按 SNMP 加进 LibreNMS 设备列表。需要 UniFi 里给 AP 开 SNMP，community
# 和下面一致；SNMP 不通只会在 bridge 日志里提示，不影响大屏/controller 监控。
UNIFI_AP_SNMP_AUTO_ADD=true
UNIFI_AP_SNMP_COMMUNITY=
UNIFI_AP_SNMP_ADD_RETRY_SECONDS=60
UNIFI_CONTROLLER_REFRESH_SECONDS=10
UNIFI_SCRAPE_INTERVAL=10s
UNIFI_AP_NAME_SYNC_SECONDS=300
COMPOSE_PROFILES=

# ==================== 赛事选手监控 ====================
PLAYER_TARGETS_REFRESH_INTERVAL=300
TOURNAMENT_SWITCHES=192.168.10.11-13
PLAYER_SUBNETS=192.168.40.0/24
WIRELESS_SUBNETS=192.168.41.0/24
# 选手网关 IP（L3 设备，承载 player VLAN 网关 / ARP 表）。
# 舞台交换机是纯 L2 时必须设置：脚本会查这里的 ARP 表拿 IP→MAC，再用
# 舞台交换机的 MAC 表反推到 team X-Y 端口。留空则回退到 LIBRENMS_CORE_IP；
# 都为空只走旧的“在舞台交换机直接 ARP”路径，纯 L2 部署会拿不到选手数据。
# 支持范围。例: PLAYER_GATEWAYS=192.168.40.254,192.168.9.5-6
PLAYER_GATEWAYS=
# 只列有线 VLAN；40 对应上面的 PLAYER_SUBNETS=192.168.40.0/24
PLAYER_VLAN_IDS=
PLAYER_REQUIRE_LINK_UP=true
PLAYER_VERIFY_PING=true
# 无线扫描：只按 WIRELESS_SUBNETS ping 扫在线 IP，生成 network=wireless 的选手 targets。
# 面板选 wired 只看有线，选 wireless 只看无线扫描，互不影响。
# 无线不知道真实座位，左右队和座位只是按 IP 排序临时分配，用来看 WiFi 连接数量/效果。
# 默认开启，比赛中可以随时切到 wireless 看有没有人连 WiFi；不需要时改成 false。
# LIMIT=0 表示不限制在线 IP 数量，只受 PLAYER_WIRELESS_SCAN_MAX_HOSTS 的扫描保护限制。
PLAYER_WIRELESS_SCAN=true
PLAYER_WIRELESS_SCAN_LIMIT=0
PLAYER_WIRELESS_SCAN_TEAM_SIZE=5
# 注意：若选手实际占用了 .1 或 .254（比如网关只在 .254、而 .1 是真选手），把本项设
# false，再用下面的 PLAYER_WIRELESS_SCAN_EXCLUDE 手动只列出真实网关，避免误排除选手。
PLAYER_WIRELESS_SCAN_EXCLUDE_GATEWAYS=true
# 额外排除 AP/网关/服务器 IP，多个用逗号分隔；支持 Cisco 风格范围。
# 例: PLAYER_WIRELESS_SCAN_EXCLUDE=192.168.12.220-254,192.168.12.10
PLAYER_WIRELESS_SCAN_EXCLUDE=
# WiFi-only 比赛可手动指定选手 IP，格式: 队伍-座位=IP[:wired|wireless]
# 例: PLAYER_STATIC_TARGETS=1-1=192.168.12.101,1-2=192.168.12.102,2-1=192.168.12.201
PLAYER_STATIC_TARGETS=
PLAYER_STATIC_NETWORK=wireless
